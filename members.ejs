<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members | Library CRM</title>

    <link rel="stylesheet" href="/css/members.css">
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
</head>

<body>

<div class="dashboard">

    <!-- Sidebar -->
    <div class="sidebar">

        <h2>Library CRM</h2>

        <ul>
            <li><a href="/dashboard"><i class="fa fa-home"></i> Dashboard</a></li>
            <li><a href="/add-member"><i class="fa fa-user-plus"></i> Add Member</a></li>
            <li><a href="/members"><i class="fa fa-users"></i> Members</a></li>
            <li><a href="/books"><i class="fa fa-book"></i> Books</a></li>
            <li><a href="#"><i class="fa fa-right-from-bracket"></i> Logout</a></li>
        </ul>

    </div>

    <!-- Main Content -->
    <div class="main">

        <div class="topbar">
            <h1>Library Members</h1>
        </div>

        <!-- Search -->
        <div class="search-box">
            <input type="text" placeholder="Search Member...">
            <button><i class="fa fa-search"></i></button>
        </div>

        <!-- Members Table -->
        <table class="member-table">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Membership</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

                <% if (members.length > 0) { %>

                    <% members.forEach(member => { %>

                    <tr>
                        <td><%= member.id %></td>
                        <td><%= member.name %></td>
                        <td><%= member.email %></td>
                        <td><%= member.phone %></td>
                        <td><%= member.membership %></td>
                        <td><%= member.status %></td>

                        <td>
                            <a href="/edit-member?id=<%= member.id %>">
                                <button>Edit</button>
                            </a>

                            <button>Delete</button>
                        </td>
                    </tr>

                    <% }) %>

                <% } else { %>

                    <tr>
                        <td colspan="7" style="text-align:center;">
                            No Members Found
                        </td>
                    </tr>

                <% } %>

            </tbody>

        </table>

    </div>

</div>

</body>
</html>